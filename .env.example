# =============================================================================
# BeautyBook SaaS — Variables de entorno (ejemplo)
# Copiar a .env y ajustar valores
# =============================================================================

NODE_ENV=development
APP_NAME=BeautyBook
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
API_PREFIX=api/v1

# PostgreSQL
DATABASE_URL=postgresql://beautybook:beautybook@localhost:5432/beautybook?schema=public
POSTGRES_USER=beautybook
POSTGRES_PASSWORD=beautybook
POSTGRES_DB=beautybook

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret-long-random
JWT_REFRESH_EXPIRES_IN=30d

# Multi-tenant
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_CURRENCY=COP
DEFAULT_LOCALE=es

# WhatsApp Bot (Baileys / WhatsApp Web)
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./bot_sessions
# Botones nativos Baileys suelen no llegar al móvil; dejar en false (texto numerado).
WHATSAPP_INTERACTIVE=true

# OpenAI (opcional — asistente FAQ)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=false

# Pagos (preparados — no activos hasta configurar)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
WOMPI_PRIVATE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@beautybook.app

# SMS (preparado)
SMS_PROVIDER=
SMS_API_KEY=

# Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
