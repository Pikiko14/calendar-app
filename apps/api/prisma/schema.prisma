generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  WORKER
  CLIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ON_THE_WAY
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  STRIPE
  MERCADOPAGO
  WOMPI
  PAYPAL
  GIFT_CARD
  OTHER
}

enum PaymentProvider {
  STRIPE
  MERCADOPAGO
  WOMPI
  PAYPAL
  LOCAL
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  PUSH
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BlockType {
  BREAK
  VACATION
  HOLIDAY
  MANUAL
  PREPARATION
  CLEANING
  TRAVEL
}

enum ProductType {
  RETAIL
  CONSUMABLE
  GIFT_CARD
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

enum WaitlistStatus {
  WAITING
  OFFERED
  BOOKED
  EXPIRED
  CANCELLED
}

enum WhatsAppConversationState {
  IDLE
  MENU
  BOOKING_SERVICE
  BOOKING_DATE
  BOOKING_TIME
  BOOKING_WORKER
  BOOKING_CONFIRM
  CONSULT
  CANCEL
  RESCHEDULE
  REVIEW
  ADVISOR
  AI_CHAT
}

// =============================================================================
// PLATFORM / MULTI-TENANT
// =============================================================================

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  email        String
  phone        String?
  logoUrl      String?
  primaryColor String       @default("#0F766E")
  accentColor  String       @default("#134E4A")
  plan         TenantPlan   @default(STARTER)
  status       TenantStatus @default(TRIAL)
  timezone     String       @default("America/Bogota")
  currency     String       @default("COP")
  locale       String       @default("es")
  address      String?
  city         String?
  country      String?
  latitude     Float?
  longitude    Float?
  mapUrl       String?
  trialEndsAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  settings          TenantSettings?
  branches          Branch[]
  users             User[]
  clients           Client[]
  workers           Worker[]
  services          Service[]
  serviceCategories ServiceCategory[]
  specialties       Specialty[]
  appointments      Appointment[]
  products          Product[]
  promotions        Promotion[]
  coupons           Coupon[]
  giftCards         GiftCard[]
  loyaltyProgram    LoyaltyProgram?
  whatsappBot       WhatsAppBotConfig?
  auditLogs         AuditLog[]
  notifications     Notification[]
  cashRegisters     CashRegister[]
  expenses          Expense[]
  invoices          Invoice[]
  waitlistEntries   WaitlistEntry[]
  reviews           Review[]

  @@index([status])
  @@index([slug])
  @@map("tenants")
}

model TenantSettings {
  id                      String   @id @default(cuid())
  tenantId                String   @unique
  minBookingNoticeMinutes Int      @default(60)
  maxBookingDaysAhead     Int      @default(60)
  cancellationMinHours    Int      @default(24)
  defaultServiceDuration  Int      @default(30)
  bufferPrepMinutes       Int      @default(0)
  bufferCleanMinutes      Int      @default(5)
  bufferTravelMinutes     Int      @default(0)
  allowOnlineBooking      Boolean  @default(true)
  requireDeposit          Boolean  @default(false)
  depositPercent          Int      @default(0)
  autoConfirm             Boolean  @default(false)
  reminderHoursBefore     Int      @default(24)
  reminder2HoursBefore    Boolean  @default(true)
  reviewRequestEnabled    Boolean  @default(true)
  waitlistEnabled         Boolean  @default(true)
  loyaltyEnabled          Boolean  @default(true)
  darkModeDefault         Boolean  @default(false)
  bookingPageTitle        String?
  bookingPageSubtitle     String?
  customCss               String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Branch {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  phone     String?
  email     String?
  address   String?
  city      String?
  latitude  Float?
  longitude Float?
  mapUrl    String?
  isMain    Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules    BranchSchedule[]
  holidays     BranchHoliday[]
  workers      Worker[]
  appointments Appointment[]
  cashRegisters CashRegister[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("branches")
}

model BranchSchedule {
  id        String    @id @default(cuid())
  branchId  String
  dayOfWeek DayOfWeek
  isClosed  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  branch Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  blocks ScheduleTimeBlock[]

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
  @@map("branch_schedules")
}

model ScheduleTimeBlock {
  id         String   @id @default(cuid())
  scheduleId String
  startTime  String // HH:mm
  endTime    String // HH:mm
  sortOrder  Int      @default(0)

  schedule BranchSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("schedule_time_blocks")
}

model BranchHoliday {
  id          String   @id @default(cuid())
  branchId    String
  date        DateTime @db.Date
  name        String
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([branchId, date])
  @@map("branch_holidays")
}

// =============================================================================
// USERS & AUTH
// =============================================================================

model User {
  id           String    @id @default(cuid())
  tenantId     String?
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  role         UserRole  @default(CLIENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  worker         Worker?
  client         Client?
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  notifications  Notification[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// =============================================================================
// WORKERS
// =============================================================================

model Worker {
  id            String    @id @default(cuid())
  tenantId      String
  branchId      String?
  userId        String?   @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  photoUrl      String?
  bio           String?
  specialties   String[]  @default([])
  color         String    @default("#0F766E")
  commissionPct Decimal   @default(0) @db.Decimal(5, 2)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  ratingAvg     Float     @default(0)
  ratingCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?             @relation(fields: [branchId], references: [id])
  user             User?               @relation(fields: [userId], references: [id])
  services         WorkerService[]
  specialtyLinks   WorkerSpecialty[]
  schedules        WorkerSchedule[]
  timeOffs         WorkerTimeOff[]
  appointments     Appointment[]
  waitlistEntries  WaitlistEntry[]
  reviews          Review[]

  @@index([tenantId, isActive])
  @@index([branchId])
  @@map("workers")
}

model Specialty {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  color     String    @default("#0F766E")
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workers WorkerSpecialty[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("specialties")
}

model WorkerSpecialty {
  workerId    String
  specialtyId String

  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([workerId, specialtyId])
  @@index([specialtyId])
  @@map("worker_specialties")
}

model WorkerService {
  workerId  String
  serviceId String

  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([workerId, serviceId])
  @@map("worker_services")
}

model WorkerSchedule {
  id        String    @id @default(cuid())
  workerId  String
  dayOfWeek DayOfWeek
  isOff     Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  worker Worker                   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  blocks WorkerScheduleTimeBlock[]

  @@unique([workerId, dayOfWeek])
  @@index([workerId])
  @@map("worker_schedules")
}

model WorkerScheduleTimeBlock {
  id         String @id @default(cuid())
  scheduleId String
  startTime  String
  endTime    String
  sortOrder  Int    @default(0)

  schedule WorkerSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("worker_schedule_time_blocks")
}

model WorkerTimeOff {
  id        String    @id @default(cuid())
  workerId  String
  type      BlockType @default(VACATION)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime  @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, startAt, endAt])
  @@map("worker_time_offs")
}

// =============================================================================
// SERVICES
// =============================================================================

model ServiceCategory {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  color       String    @default("#64748B")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([tenantId])
  @@map("service_categories")
}

model Service {
  id              String    @id @default(cuid())
  tenantId        String
  categoryId      String?
  name            String
  description     String?
  durationMinutes Int
  price           Decimal   @db.Decimal(12, 2)
  color           String    @default("#0F766E")
  prepMinutes     Int       @default(0)
  cleanMinutes    Int       @default(0)
  travelMinutes   Int       @default(0)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  imageUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  workers      WorkerService[]
  appointments Appointment[]
  waitlistEntries WaitlistEntry[]

  @@index([tenantId, isActive])
  @@index([categoryId])
  @@map("services")
}

// =============================================================================
// CLIENTS
// =============================================================================

model Client {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String?   @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  whatsapp      String?
  birthday      DateTime? @db.Date
  notes         String?
  tags          String[]  @default([])
  totalSpent    Decimal   @default(0) @db.Decimal(14, 2)
  visitCount    Int       @default(0)
  lastVisitAt   DateTime?
  loyaltyPoints Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?                @relation(fields: [userId], references: [id])
  appointments    Appointment[]
  loyaltyTxns     LoyaltyTransaction[]
  waitlistEntries WaitlistEntry[]
  giftCards       GiftCard[]
  reviews         Review[]
  whatsappConvos  WhatsAppConversation[]

  @@unique([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, whatsapp])
  @@map("clients")
}

// =============================================================================
// APPOINTMENTS (CORE)
// =============================================================================

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  branchId        String?
  clientId        String
  workerId        String
  serviceId       String
  status          AppointmentStatus @default(PENDING)
  startAt         DateTime
  endAt           DateTime
  // Buffer windows (stored for conflict detection)
  bufferStartAt   DateTime
  bufferEndAt     DateTime
  price           Decimal           @db.Decimal(12, 2)
  discount        Decimal           @default(0) @db.Decimal(12, 2)
  depositAmount   Decimal           @default(0) @db.Decimal(12, 2)
  notes           String?
  internalNotes   String?
  source          String            @default("web") // web | whatsapp | admin | walk-in
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  completedAt     DateTime?
  noShowAt        DateTime?
  rescheduledFrom String?
  version         Int               @default(1) // optimistic locking
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?          @relation(fields: [branchId], references: [id])
  client     Client           @relation(fields: [clientId], references: [id])
  worker     Worker           @relation(fields: [workerId], references: [id])
  service    Service          @relation(fields: [serviceId], references: [id])
  payments   Payment[]
  review     Review?
  timeBlocks CalendarBlock[]

  @@index([tenantId, startAt, endAt])
  @@index([workerId, startAt, endAt])
  @@index([clientId, startAt])
  @@index([tenantId, status])
  @@index([branchId, startAt])
  // Exclusion constraint handled via raw SQL migration for overlap prevention
  @@map("appointments")
}

model CalendarBlock {
  id            String    @id @default(cuid())
  tenantId      String
  workerId      String?
  branchId      String?
  appointmentId String?
  type          BlockType
  startAt       DateTime
  endAt         DateTime
  title         String?
  reason        String?
  createdAt     DateTime  @default(now())

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, startAt, endAt])
  @@index([workerId, startAt, endAt])
  @@map("calendar_blocks")
}

// =============================================================================
// WAITLIST
// =============================================================================

model WaitlistEntry {
  id        String         @id @default(cuid())
  tenantId  String
  clientId  String
  serviceId String
  workerId  String?
  preferredDate DateTime?  @db.Date
  preferredTime String?
  status    WaitlistStatus @default(WAITING)
  notifiedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  worker  Worker? @relation(fields: [workerId], references: [id])

  @@index([tenantId, status])
  @@map("waitlist_entries")
}

// =============================================================================
// PAYMENTS
// =============================================================================

model Payment {
  id              String          @id @default(cuid())
  tenantId        String
  appointmentId   String?
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("COP")
  status          PaymentStatus   @default(PENDING)
  method          PaymentMethod   @default(CASH)
  provider        PaymentProvider @default(LOCAL)
  providerRef     String?
  isDeposit       Boolean         @default(false)
  metadata        Json?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId, status])
  @@index([appointmentId])
  @@map("payments")
}

// =============================================================================
// PRODUCTS / INVENTORY / POS
// =============================================================================

model Product {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  sku         String?
  description String?
  type        ProductType @default(RETAIL)
  price       Decimal     @db.Decimal(12, 2)
  cost        Decimal     @default(0) @db.Decimal(12, 2)
  stock       Int         @default(0)
  minStock    Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model CashRegister {
  id          String    @id @default(cuid())
  tenantId    String
  branchId    String?
  openedById  String?
  openingFloat Decimal  @default(0) @db.Decimal(12, 2)
  closingCash  Decimal? @db.Decimal(12, 2)
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId, openedAt])
  @@map("cash_registers")
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime @db.Date
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
  @@map("expenses")
}

model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  number      String
  clientId    String?
  subtotal    Decimal  @db.Decimal(12, 2)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  issuedAt    DateTime @default(now())
  pdfUrl      String?
  metadata    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("invoices")
}

// =============================================================================
// MARKETING / LOYALTY
// =============================================================================

model Promotion {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  discountPct Int?
  discountAmt Decimal?  @db.Decimal(12, 2)
  startAt     DateTime
  endAt       DateTime
  lowOccupancyOnly Boolean @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("promotions")
}

model Coupon {
  id          String    @id @default(cuid())
  tenantId    String
  code        String
  discountPct Int?
  discountAmt Decimal?  @db.Decimal(12, 2)
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("coupons")
}

model GiftCard {
  id        String    @id @default(cuid())
  tenantId  String
  clientId  String?
  code      String
  balance   Decimal   @db.Decimal(12, 2)
  initial   Decimal   @db.Decimal(12, 2)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  @@unique([tenantId, code])
  @@map("gift_cards")
}

model LoyaltyProgram {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  pointsPerCurrency Decimal @default(1) @db.Decimal(8, 2)
  redemptionRate  Decimal @default(100) @db.Decimal(8, 2) // points per currency unit
  isActive        Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id        String                 @id @default(cuid())
  clientId  String
  type      LoyaltyTransactionType
  points    Int
  reason    String?
  createdAt DateTime               @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("loyalty_transactions")
}

model Review {
  id            String   @id @default(cuid())
  tenantId      String
  workerId      String
  appointmentId String   @unique
  clientId      String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  worker      Worker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([tenantId])
  @@index([workerId])
  @@map("reviews")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String              @id @default(cuid())
  tenantId  String
  userId    String?
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  to        String
  subject   String?
  body      String
  metadata  Json?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, status])
  @@index([channel, status])
  @@map("notifications")
}

// =============================================================================
// WHATSAPP BOT
// =============================================================================

model WhatsAppBotConfig {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  enabled      Boolean  @default(true)
  phoneNumber  String?
  welcomeMsg   String   @default("Bienvenido. ¿Cómo podemos ayudarte?\n1 Reservar cita\n2 Consultar cita\n3 Cancelar cita\n4 Reprogramar\n5 Promociones\n6 Hablar con un asesor")
  businessName String?
  sessionData  Json?
  aiEnabled    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("whatsapp_bot_configs")
}

model WhatsAppConversation {
  id          String                    @id @default(cuid())
  tenantId    String
  clientId    String?
  phone       String
  state       WhatsAppConversationState @default(IDLE)
  context     Json?
  lastMessage String?
  updatedAt   DateTime                  @updatedAt
  createdAt   DateTime                  @default(now())

  client Client? @relation(fields: [clientId], references: [id])

  @@unique([tenantId, phone])
  @@index([tenantId, state])
  @@map("whatsapp_conversations")
}

// =============================================================================
// AUDIT
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String?
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
