{
  "name": "beautybook",
  "version": "1.0.0",
  "private": true,
  "description": "SaaS multi-tenant de gestión de barberías, peluquerías y SPA",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=api",
    "dev:web": "npm run dev --workspace=beautybook-web",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=beautybook-web",
    "build": "npm run build:api && npm run build:web",
    "prisma:generate": "npm run prisma:generate --workspace=api",
    "prisma:migrate": "npm run prisma:migrate --workspace=api",
    "prisma:seed": "npm run prisma:seed --workspace=api",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "docker:full": "docker compose up -d --build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
